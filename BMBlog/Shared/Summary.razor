@inject ILogger<Summary> Logger
@inject IToCParser Parser
<div class="top-row pl-4 navbar navbar-dark">
    <a class="navbar-brand" href="/">home</a>
    <button class="navbar-toggler" @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
    </button>
</div>
<div class="@NavMenuCssClass" @onclick="ToggleNavMenu">
    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
        <span class="oi oi-home" aria-hidden="true"></span> Home
    </NavLink>
    @foreach (var link in links)
    {
        <Link SideNav="link"></Link>
    }
</div>
@code {
    public List<SideNavItem> links { get; set; } = new List<SideNavItem>();
    bool collapseNavMenu = true;

    string NavMenuCssClass => collapseNavMenu ? "collapsed" : null;

    void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
        this.StateHasChanged();
    }


    async protected override Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        Logger.LogWarning("start loading summary");
        links = (await Parser.Parse()).ToList();
        links.ForEach(x => Logger.LogInformation(x.ToString()));
        Logger.LogWarning("end loading summary");
        this.StateHasChanged();
    }
}
