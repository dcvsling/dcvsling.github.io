@layout MainLayout

<MdBlock></MdBlock>

@code {

    [Inject]
    private NavigationManager Navigation { get; set; }
    [Inject]
    private IContentParser Parser { get; set; }
    protected override void OnAfterRender(bool firstRender) {
        Parser.Parse(new SideNavItem { Link = URL.Parse(Navigation.Uri).Path });
    }
}